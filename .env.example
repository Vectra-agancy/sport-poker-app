# ─── Prisma / SQLite (dev) ────────────────────────────────
DATABASE_URL="file:./dev.db"
# Для prod-Postgres использовать:
# DATABASE_URL="postgresql://user:password@host:5432/reraise?schema=public"

# ─── Auth.js v5 ───────────────────────────────────────────
# Сгенерировать: `openssl rand -base64 32`
AUTH_SECRET=""
# В dev можно не задавать — Auth.js подставит NEXTAUTH_URL=http://localhost:3000.
# В prod обязательно: AUTH_URL="https://reraise.club"
# AUTH_URL=""

# ─── Telegram WebApp ─────────────────────────────────────
# Bot token от @BotFather. Без него Telegram-логин отключён.
TELEGRAM_BOT_TOKEN=""

# ─── Email OTP через Resend ──────────────────────────────
# Без RESEND_API_KEY коды OTP логируются в консоль (dev-режим).
RESEND_API_KEY=""
EMAIL_FROM="RERAISE CLUB <noreply@reraise.club>"
