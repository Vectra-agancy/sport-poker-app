# ─── Prisma / Turso (libSQL) ──────────────────────────────
# Turso URL с встроенным authToken — используется и Prisma CLI, и runtime adapter.
# Получить: turso db tokens create <db-name>
DATABASE_URL="libsql://your-db.turso.io?authToken=your-jwt-token"

# Локальный SQLite для dev можно задать так (требует @prisma/adapter-better-sqlite3):
# DATABASE_URL="file:./dev.db"

# ─── Auth.js v5 ───────────────────────────────────────────
# Сгенерировать секрет: `openssl rand -base64 32`
AUTH_SECRET=""
# В prod на Vercel задаётся автоматически через VERCEL_URL.
# В кастомном хостинге: AUTH_URL="https://reraise.club"

# ─── Telegram WebApp ─────────────────────────────────────
# Без TELEGRAM_BOT_TOKEN Telegram-логин отключён.
TELEGRAM_BOT_TOKEN=""

# ─── Email OTP через Resend ──────────────────────────────
# Без RESEND_API_KEY OTP-коды логируются в консоль (dev-режим).
RESEND_API_KEY=""
EMAIL_FROM="RERAISE CLUB <noreply@reraise.club>"
